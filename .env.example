NODE_ENV=development
PORT=8080

POSTGRES_URL=postgres://postgres:postgres@127.0.0.1:5432/postgres
REDIS_URL=redis://127.0.0.1:6379
RATE_LIMIT_PER_MINUTE=60
ADMIN_STATUS_TOKEN=
ALLOW_DEMO_PAYMENT_CONFIRM=true
ALLOW_DEV_API_KEY_PREFIX=false

BKASH_WEBHOOK_SECRET=bkash-secret
SSLCOMMERZ_WEBHOOK_SECRET=sslcommerz-secret

# Optional provider-side verification endpoints
BKASH_VERIFY_ENDPOINT=
BKASH_BEARER_TOKEN=

SSLCOMMERZ_VALIDATOR_ENDPOINT=
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=

# Provider configuration
PROVIDER_MAX_RETRIES=1
PROVIDER_TIMEOUT_MS=4000

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_FREE_MODEL=
ANTHROPIC_MAX_RETRIES=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_TIMEOUT_MS=

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_FREE_MODEL=
GEMINI_MAX_RETRIES=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TIMEOUT_MS=

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_FREE_MODEL=
GROQ_MAX_RETRIES=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_MS=

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_FREE_MODEL=
OLLAMA_MAX_RETRIES=
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_MS=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_FREE_MODEL=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_MAX_RETRIES=
OPENAI_TIMEOUT_MS=

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_FREE_MODEL=
OPENROUTER_MAX_RETRIES=
OPENROUTER_MODEL=
OPENROUTER_TIMEOUT_MS=

# Supabase (Option A migration)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=dev-service-role
SUPABASE_AUTH_ENABLED=false
SUPABASE_USER_REPO_ENABLED=false
SUPABASE_API_KEYS_ENABLED=false
SUPABASE_BILLING_STORE_ENABLED=false
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Local Langfuse tracing
# NOTE: LANGFUSE_BASE_URL uses docker-compose service name ("langfuse:3000").
# Outside docker-compose, replace with http://localhost:3030 or your Langfuse host.
LANGFUSE_BASE_URL=http://langfuse:3000
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here
