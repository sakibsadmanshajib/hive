# Copy this file to `.env` and fill in the blanks for local development.
# This repo does not read `NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY`.
# If Supabase shows you a browser "publishable" key, paste that same value into:
# `SUPABASE_ANON_KEY`
# `NEXT_PUBLIC_SUPABASE_ANON_KEY`
# Leave `SUPABASE_SERVICE_ROLE_KEY` and `SUPABASE_DB_URL` blank unless you are
# running the control-plane against your own Supabase project locally.

# Supabase
SUPABASE_URL=https://yimgflllgdsbcibnaxqe.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Control-plane / Redis
REDIS_URL=redis://redis:6379/0
CONTROL_PLANE_PORT=8081
CONTROL_PLANE_BASE_URL=http://localhost:8081
EDGE_CONTROL_PLANE_BASE_URL=http://control-plane:8081
LITELLM_MASTER_KEY=litellm-dev-key
OPENROUTER_API_KEY=
GROQ_API_KEY=
# OpenRouter routing. "openrouter/free" disperses load across OR's free-model pool,
# avoiding single-model rate caps hit under concurrent CI SDK suites.
# See https://openrouter.ai/openrouter/free
OPENROUTER_DEFAULT_MODEL=openrouter/free
OPENROUTER_AUTO_MODEL=openrouter/free
OPENROUTER_FAST_FALLBACK_MODEL=openrouter/free
# OpenRouter free embedding model (multimodal text/image embeddings).
# Highly rate-limited — edge-api applies a bounded retry on 429.
OPENROUTER_EMBEDDING_MODEL=openrouter/nvidia/llama-nemotron-embed-vl-1b-v2:free
GROQ_FAST_MODEL=

# Supabase Storage (S3-compatible)
# Enable S3 protocol in Supabase Dashboard > Storage > S3 Access.
# Create the buckets hive-files and hive-images before starting the stack.
# Copy the endpoint, region, access key, and secret key from Supabase Storage S3 settings.
S3_ENDPOINT=https://yimgflllgdsbcibnaxqe.supabase.co/storage/v1/s3
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_BUCKET_FILES=hive-files
S3_BUCKET_IMAGES=hive-images

# Web console
NEXT_PUBLIC_SUPABASE_URL=https://yimgflllgdsbcibnaxqe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Hive API key for smoke tests / SDK tests (create one via POST /v1/keys)
HIVE_API_KEY=
