# Copy this file to `.env` and fill in the blanks for local development.
# If Supabase gives you a browser "publishable" key, use that value for both
# `SUPABASE_ANON_KEY` and `NEXT_PUBLIC_SUPABASE_ANON_KEY` in this repo.

# Supabase
SUPABASE_URL=https://yimgflllgdsbcibnaxqe.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Control-plane / Redis
REDIS_URL=redis://redis:6379/0
CONTROL_PLANE_PORT=8081
CONTROL_PLANE_BASE_URL=http://localhost:8081

# Web console
NEXT_PUBLIC_SUPABASE_URL=https://yimgflllgdsbcibnaxqe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
