# Copy this file to `.env` and fill in the blanks for local development.
# This repo does not read `NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY`.
# If Supabase shows you a browser "publishable" key, paste that same value into:
# `SUPABASE_ANON_KEY`
# `NEXT_PUBLIC_SUPABASE_ANON_KEY`
# Leave `SUPABASE_SERVICE_ROLE_KEY` and `SUPABASE_DB_URL` blank unless you are
# running the control-plane against your own Supabase project locally.

# Supabase
SUPABASE_URL=https://yimgflllgdsbcibnaxqe.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
SUPABASE_JWT_ISSUER=https://yimgflllgdsbcibnaxqe.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWKS_URL=https://yimgflllgdsbcibnaxqe.supabase.co/auth/v1/.well-known/jwks.json

# Control-plane / Redis
#
# Local dev (default below): the in-stack docker redis lives in the `local`
# profile of deploy/docker/docker-compose.yml. Run with
# `docker compose --profile local --env-file ../../.env up --build`.
#
# Staging + production: REDIS_URL must point at a managed Upstash Redis
# instance over TLS, e.g. `rediss://default:<token>@<host>:6379`. The Go
# clients (edge-api + control-plane) use go-redis/v9's ParseURL and
# asynq.ParseRedisURI — both accept rediss:// natively, so no code change
# is required between local docker redis and Upstash. Never seed a
# `redis://redis:6379/0`-style value into the staging `.env` —
# .github/workflows/deploy-staging.yml asserts against it.
REDIS_URL=redis://redis:6379/0
CONTROL_PLANE_PORT=8081
CONTROL_PLANE_BASE_URL=http://localhost:8081
EDGE_CONTROL_PLANE_BASE_URL=http://control-plane:8081
LITELLM_MASTER_KEY=litellm-dev-key
# Provider keys (FREE tier used in CI)
OPENROUTER_API_KEY=            # OpenRouter free router (primary)
GROQ_API_KEY=                  # Groq free (chat fallback + reasoning)
NVIDIA_NIM_API_KEY=            # NVIDIA NIM free (embeddings fallback)

# OpenRouter routing. "openrouter/free" disperses load across OR's free-model pool.
# Failures cascade via LiteLLM fallbacks to the Groq routes below.
OPENROUTER_DEFAULT_MODEL=openrouter/free
OPENROUTER_AUTO_MODEL=openrouter/free
OPENROUTER_FAST_FALLBACK_MODEL=openrouter/free

# OpenRouter free multimodal embedding (text+image -> embeddings).
# Highly rate-limited — edge-api bounded retry + LiteLLM fallback to NVIDIA NIM.
# Note: LiteLLM's `/embeddings` adapter does NOT currently map OpenRouter
# `:free` aliases. Leave the canonical model name without the `:free`
# suffix; OpenRouter still routes the request through the free pool when
# the underlying model is gated as free. If LiteLLM rejects this with
# "Unmapped LLM provider", treat the route as a no-op and rely on the
# NVIDIA NIM primary — the LiteLLM `litellm_settings.fallbacks` block
# already declares the cascade direction.
OPENROUTER_EMBEDDING_MODEL=openrouter/nvidia/llama-nemotron-embed-vl-1b-v2

# Groq free chat/reasoning models (gpt-oss-20b primary, 120b reasoning).
GROQ_FAST_MODEL=groq/openai/gpt-oss-20b
GROQ_REASONING_MODEL=groq/openai/gpt-oss-120b

# NVIDIA NIM embedding model. The previous default
# `nvidia/llama-3.2-nemoretriever-300m-embed-v1` reached end-of-life on
# 2026-05-18 and now returns HTTP 410 from NIM. Replacement is the
# `nv-embedqa-1b-v2` retrieval encoder — same retriever-style architecture
# with the same `input_type=passage|query` asymmetric setup that the
# LiteLLM `route-nvidia-embedding` block already configures.
#
# Confirm the latest stable model at https://build.nvidia.com/explore/retrieval
# before bumping; live CI uses the value from the Actions environment.
NVIDIA_NIM_EMBEDDING_MODEL=nvidia_nim/nvidia/llama-3.2-nv-embedqa-1b-v2

# ─── Phase 15: Local batch executor (POST /v1/batches success-path) ───
# Concurrency cap for in-flight per-line dispatches. Default 8; ceiling 32.
BATCH_EXECUTOR_CONCURRENCY=8
# Bounded retries on transient failures (5xx, 408, 429, network errors). 4xx
# (400/401/403/404/422) fail immediately. Default 3; ceiling 5.
BATCH_EXECUTOR_MAX_RETRIES=3
# Per-line context timeout in milliseconds. Default 60000 (60s); floor 5000;
# ceiling 300000 (5min).
BATCH_EXECUTOR_LINE_TIMEOUT_MS=60000
# Dispatch strategy: "auto" reads route_capabilities.executor_kind (default
# local for openrouter/groq); "local" forces the in-process executor; "upstream"
# forces the existing LiteLLM upstream batch-file path (only works for
# openai/azure/vertex/anthropic providers).
BATCH_EXECUTOR_KIND=auto

# Supabase Storage (S3-compatible)
# Enable S3 protocol in Supabase Dashboard > Storage > S3 Access.
# Create the buckets hive-files and hive-images before starting the stack.
# Copy the endpoint, region, access key, and secret key from Supabase Storage S3 settings.
S3_ENDPOINT=https://yimgflllgdsbcibnaxqe.supabase.co/storage/v1/s3
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_BUCKET_FILES=hive-files
S3_BUCKET_IMAGES=hive-images

# Web console
NEXT_PUBLIC_SUPABASE_URL=https://yimgflllgdsbcibnaxqe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Hive API key for smoke tests / SDK tests (create one via POST /v1/keys)
HIVE_API_KEY=

# Endpoints used by the staging-flows E2E probe (override per environment).
PLAYWRIGHT_BASE_URL=https://console-hive.scubed.co
HIVE_EDGE_API_URL=https://api-hive.scubed.co
HIVE_CONTROL_PLANE_URL=https://cp-hive.scubed.co

# QA test users for the staging-flows E2E probe.
HIVE_QA_TESTER_EMAIL=
HIVE_QA_TESTER_PASSWORD=
HIVE_QA_UNVERIFIED_EMAIL=
HIVE_QA_UNVERIFIED_PASSWORD=

# ─── Phase 19: Open WebUI + Supabase OAuth ───
HIVE_CHAT_URL=http://localhost:3003
SUPABASE_OAUTH_CLIENT_ID=
SUPABASE_OAUTH_CLIENT_SECRET=
SUPABASE_WEBHOOK_SECRET=
OWUI_BASE_URL=http://open-webui:8080
OWUI_ADMIN_TOKEN=
OWUI_E2E_MODE=false

# ─── Phase 19: audit sinks (all optional) ───
AUDIT_SINK_FAILURE_GRACE_MINUTES=5
AUDIT_SINK_ELK_URL=
AUDIT_SINK_ELK_API_KEY=
AUDIT_SINK_LOKI_URL=
AUDIT_SINK_DATADOG_API_KEY=
AUDIT_SINK_DATADOG_SITE=datadoghq.com
AUDIT_SINK_SPLUNK_HEC_URL=
AUDIT_SINK_SPLUNK_HEC_TOKEN=
SENTRY_DSN=

# Langfuse
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_INCLUDE_CONTENT=false

# Audit retention + WAL
AUDIT_WAL_DIR=/var/lib/hive/audit-wal
AUDIT_COLD_ARCHIVE_RETENTION_YEARS=7
AUDIT_PARTITION_MONTHS_HOT=3

# Grafana admin credentials (required when running --profile monitoring).
# The previous baked-in admin/admin default was a hardcoded-credential
# regression and is no longer tolerated — the service refuses to start
# without these values.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
