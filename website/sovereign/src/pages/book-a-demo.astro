---
// Book a Demo (NEW PAGE). A short, on-brand dossier page so the site's primary
// CTA resolves to a real route. No payment, no heavy form: a clear ask, a
// mailto contact method, and one line on what happens next. Art direction
// matches the Home dossier exactly: numbered hairline SectionShell sections,
// Fraunces H2 type role, margin labels, ink closing surface, AA contrast,
// single forest accent, off-white base, zero client JS, CSP-clean (no inline
// style attrs, no inline script). Exactly one H1.
//
// Claim rules honoured: designed-to-support language only, "sovereignty" not
// asserted loosely here (the page is operational, not a claims page); Canadian
// English; no dash punctuation between clauses. The demo line matches Home's
// closing copy ("running locally, with no data leaving the box"), which is the
// architectural property, not a certification.
//
// The mailto target is a placeholder (demo@hive.scubed.co) per the brief; swap
// it for the live address before launch.
import Base from '../layouts/Base.astro';
import SectionShell from '../components/SectionShell.astro';

const demoEmail = 'demo@hive.scubed.co';
const mailtoSubject = encodeURIComponent('Hive demo request');
const mailtoBody = encodeURIComponent(
  'Tell us a little about your team:\n\n' +
    '- Organisation:\n' +
    '- Sector (finance, healthcare, legal, government, other):\n' +
    '- The work you would run AI on:\n' +
    '- Any hard data rule we should know about:\n',
);
const mailtoHref = `mailto:${demoEmail}?subject=${mailtoSubject}&body=${mailtoBody}`;

// What happens after you reach out, three short steps.
const steps = [
  {
    numeral: '01',
    title: 'You tell us the shape of the work.',
    body: 'A short note on your sector, the work you want AI to do, and any rule that says your data cannot leave your control. No long form, no sales script.',
  },
  {
    numeral: '02',
    title: 'We show Hive running locally.',
    body: 'A short live session where Hive runs on a box, with no prompt, no document, and no response leaving that box. You see the architecture, not a slide about it.',
  },
  {
    numeral: '03',
    title: 'We place you on the spectrum.',
    body: 'We recommend the tier that fits your data and budget, from a box you own on-prem to a region-locked shared instance, and we are honest about the trade at each one.',
  },
];
---

<Base
  title="Book a Demo"
  description="See Hive run on a box, with no prompt, document, or response leaving it. Tell us about your work and we will show the architecture live and recommend the tier that fits."
  structuredData={{
    breadcrumbs: [
      { name: 'Home', url: 'https://hive.scubed.co/' },
      { name: 'Book a Demo', url: 'https://hive.scubed.co/book-a-demo' },
    ],
  }}
>
  {/* ============ HERO (single editorial column with the primary ask) ============ */}
  <section class="hero" aria-labelledby="hero-h1">
    <div class="shell hero__col load-rise">
      <p class="hero__meta">
        <span class="hero__tag">Book a demo</span>
        <span class="hero__metasep" aria-hidden="true">&#183;</span>
        <span class="hero__tag">Short and live</span>
        <span class="hero__metasep" aria-hidden="true">&#183;</span>
        <span class="hero__tag">No data leaves the box</span>
      </p>
      <h1 id="hero-h1" class="hero__h1">
        See it run inside your own network.
      </h1>
      <p class="hero__lede">
        Book a short demo and we will show Hive running locally, with no prompt,
        no document, and no response leaving the box. Then we will recommend the
        tier that fits your data and your budget.
      </p>
      <div class="cta-row">
        <a class="cta cta--primary tap-target" href={mailtoHref}>
          Email us to book
        </a>
        <a class="cta cta--ghost tap-target" href="/how-you-run-hive">
          See how you run Hive
        </a>
      </div>
      <p class="hero__addr">
        Or write to
        <a class="textlink" href={mailtoHref}>{demoEmail}</a>
        with a line about your team.
      </p>
    </div>
  </section>

  {/* ============ 01 WHAT TO SEND ============ */}
  <SectionShell numeral="01" label="The ask" id="ask-h2">
    <h2 class="section-h2 section-h2--lead">
      One short note is all we need to start.
    </h2>
    <div class="prose">
      <p>
        There is no long form and no account to create. Send us a short message
        and we will reply to arrange a time. The more you can tell us about the
        work and your constraints, the more useful the first session is, but a
        single line is enough to begin.
      </p>
    </div>

    <div class="ds__bleed ask">
      <span class="ask__label">A useful note covers</span>
      <ul class="ask__list" role="list">
        <li class="ask__item">Your organisation and sector.</li>
        <li class="ask__item">The work you want to run AI on.</li>
        <li class="ask__item">Any hard rule that says your data cannot leave your control.</li>
      </ul>
      <a class="cta cta--primary tap-target ask__cta" href={mailtoHref}>
        Email us to book
      </a>
    </div>
  </SectionShell>

  {/* ============ 02 WHAT HAPPENS NEXT ============ */}
  <SectionShell numeral="02" label="What happens next" id="next-h2">
    <h2 class="section-h2">Three steps, no pressure.</h2>
    <p class="prose prose--single">
      The first conversation is short and technical. We would rather show you the
      architecture working than talk around it.
    </p>

    <ol class="ds__bleed steps" role="list">
      {
        steps.map((s) => (
          <li class="step">
            <span class="step__numeral font-mono" data-numeric>
              {s.numeral}
            </span>
            <div class="step__body">
              <h3 class="step__title">{s.title}</h3>
              <p class="step__text">{s.body}</p>
            </div>
          </li>
        ))
      }
    </ol>

    <p class="prose__after">
      Not sure which tier fits yet?
      <a class="textlink" href="/how-you-run-hive">Compare the three tiers</a>
      or
      <a class="textlink" href="/pricing">see the cost model</a>
      first.
    </p>
  </SectionShell>

  {/* ============ CLOSING CTA (ink, the one deliberate dark surface) ============ */}
  <section class="closing" aria-labelledby="closing-h2">
    <div class="shell narrow closing__inner">
      <h2 id="closing-h2" class="section-h2 section-h2--lead closing__h2">
        Tell us about your work. We will show you the box.
      </h2>
      <p class="closing__line">
        Reach out and we will set up a short session on the kind of work your
        team does every day.
      </p>
      <div class="cta-row">
        <a class="cta cta--on-ink tap-target" href={mailtoHref}>
          Email us to book
        </a>
        <a class="cta cta--ghost-ink tap-target" href="/use-cases">
          See use cases
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* =========================================================================
     SHARED TYPE ROLES (ported from the Home dossier so this page matches it)
     ========================================================================= */
  .section-h2 {
    margin: 0 0 var(--space-6);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-h2-dossier);
    line-height: var(--lh-heading);
    letter-spacing: -0.01em;
    color: var(--text);
    max-width: 22ch;
  }

  .section-h2--lead {
    max-width: 24ch;
  }

  .prose {
    color: var(--text);
    font-size: var(--text-base);
    line-height: var(--lh-body);
  }

  .prose p {
    margin: 0 0 var(--space-5);
    max-width: 68ch;
  }

  .prose p:last-child {
    margin-bottom: 0;
  }

  .prose--single {
    margin: var(--space-5) 0 0;
    max-width: 66ch;
  }

  .prose__after {
    margin: var(--space-7) 0 0;
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: var(--lh-body);
    max-width: 68ch;
  }

  .textlink {
    color: var(--accent);
    font-weight: 600;
    border-bottom: 1px solid var(--accent-line);
    padding-bottom: 1px;
    transition: border-color var(--dur-fast) var(--ease-out);
  }

  .textlink:hover {
    border-bottom-color: var(--accent);
  }

  .narrow {
    max-width: 800px;
  }

  /* =========================================================================
     CTA BUTTONS (identical to Home; verified contrast ratios apply)
     ========================================================================= */
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-7);
  }

  .cta {
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.01em;
    padding: 14px 26px;
    border-radius: var(--radius-sm);
    transition: background-color var(--dur-base) var(--ease-out),
                border-color var(--dur-base) var(--ease-out),
                transform var(--dur-base) var(--ease-out);
  }

  .cta--primary {
    background-color: var(--accent);
    color: var(--bg);
    border: 1px solid var(--accent);
  }

  .cta--primary:hover {
    background-color: var(--accent-hover);
    border-color: var(--accent-hover);
    transform: translateY(-1px);
  }

  .cta--ghost {
    background-color: transparent;
    color: var(--text);
    border: 1px solid var(--border-strong);
  }

  .cta--ghost:hover {
    border-color: var(--text-faint);
    transform: translateY(-1px);
  }

  .cta--on-ink {
    background-color: var(--on-ink);
    color: var(--ink);
    border: 1px solid var(--on-ink);
  }

  .cta--on-ink:hover {
    background-color: #ffffff;
    border-color: #ffffff;
    transform: translateY(-1px);
  }

  .cta--ghost-ink {
    background-color: transparent;
    color: var(--on-ink);
    border: 1px solid var(--on-ink-border);
  }

  .cta--ghost-ink:hover {
    border-color: var(--on-ink);
    transform: translateY(-1px);
  }

  /* =========================================================================
     HERO (single editorial column; matches Home's meta-row and type scale)
     ========================================================================= */
  .hero {
    padding-block: var(--space-8) var(--space-8);
  }

  .hero__col {
    max-width: 44rem;
  }

  .hero__meta {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border);
  }

  .hero__tag {
    color: var(--text-muted);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero__metasep {
    color: var(--text-faint);
  }

  .hero__h1 {
    margin: var(--space-6) 0 0;
    font-size: clamp(40px, 5vw, 64px);
    line-height: var(--lh-tight);
    letter-spacing: -0.02em;
    max-width: 16ch;
  }

  .hero__lede {
    margin: var(--space-6) 0 0;
    color: var(--text-muted);
    font-size: var(--text-md);
    line-height: var(--lh-body);
    max-width: 58ch;
  }

  .hero__addr {
    margin: var(--space-6) 0 0;
    color: var(--text-faint);
    font-size: var(--text-sm);
    line-height: var(--lh-snug);
  }

  /* =========================================================================
     ASK PANEL (accent-wash, matches Home's faceline/callout treatment)
     ========================================================================= */
  .ask {
    margin: var(--space-7) 0 0;
    padding: var(--space-6) var(--space-7);
    background-color: var(--accent-wash);
    border: 1px solid var(--accent-line);
    border-radius: var(--radius-card);
  }

  .ask__label {
    display: block;
    margin-bottom: var(--space-4);
    color: var(--accent);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .ask__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .ask__item {
    position: relative;
    padding-left: var(--space-6);
    color: var(--text);
    font-size: var(--text-base);
    line-height: var(--lh-snug);
  }

  .ask__item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 14px;
    height: 2px;
    background-color: var(--accent);
  }

  .ask__cta {
    margin-top: var(--space-6);
  }

  /* =========================================================================
     STEPS (numbered, hairline-separated, matches Home's exposure/proof stacks)
     ========================================================================= */
  .steps {
    list-style: none;
    margin: var(--space-8) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-6);
  }

  .step {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--space-5);
    border-top: 1px solid var(--border-strong);
    padding-top: var(--space-5);
  }

  .step__numeral {
    color: var(--accent);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .step__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .step__title {
    margin: 0;
    font-size: var(--text-h3);
    line-height: var(--lh-heading);
    color: var(--text);
  }

  .step__text {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-base);
    line-height: var(--lh-snug);
    max-width: 64ch;
  }

  /* =========================================================================
     CLOSING (ink, the one deliberate dark surface on this page)
     ========================================================================= */
  .closing {
    background-color: var(--ink);
    color: var(--on-ink);
    border-top: 1px solid var(--on-ink-border);
    padding-block: var(--space-9);
    position: relative;
    overflow: hidden;
  }

  .closing__inner {
    position: relative;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 1;
  }

  .closing__h2 {
    color: var(--on-ink);
    max-width: 22ch;
  }

  .closing__line {
    margin: 0;
    color: var(--on-ink-muted);
    font-size: var(--text-md);
    line-height: var(--lh-body);
    max-width: 52ch;
  }

  .closing .cta-row {
    justify-content: center;
  }

  /* =========================================================================
     PAGE-LOAD REVEAL (matches Home; guarded, never hides content)
     ========================================================================= */
  @media (prefers-reduced-motion: no-preference) {
    .load-rise {
      animation: load-rise var(--dur-reveal) var(--ease-out) both;
    }
    .load-rise > * {
      animation: load-rise var(--dur-reveal) var(--ease-out) both;
    }
    .load-rise > *:nth-child(1) { animation-delay: 40ms; }
    .load-rise > *:nth-child(2) { animation-delay: 110ms; }
    .load-rise > *:nth-child(3) { animation-delay: 180ms; }
    .load-rise > *:nth-child(4) { animation-delay: 250ms; }
    .load-rise > *:nth-child(5) { animation-delay: 320ms; }
  }

  @keyframes load-rise {
    from {
      transform: translateY(var(--reveal-shift));
      opacity: 0.6;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  /* =========================================================================
     RESPONSIVE
     ========================================================================= */
  @media (max-width: 880px) {
    .hero {
      padding-block: var(--space-7) var(--space-8);
    }
    .step {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
  }
</style>
