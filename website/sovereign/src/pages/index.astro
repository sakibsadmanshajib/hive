<style>
  /* =========================================================================
     SECTION WRAPPERS (replaces SectionShell on the Home page)
     Off-white editorial bands: a top hairline rule plus consistent vertical
     padding give the rhythm SectionShell used to provide, without the dossier
     margin column. All content lives inside .shell (max-width 1140px), centred.
     Ink bands (.oneliner, .closing) define their own surface below and skip the
     top hairline (the colour change is the divider).
     ========================================================================= */
  .band {
    border-top: 1px solid var(--border);
    padding-block: var(--space-9);
    background-color: var(--bg);
  }

  /* =========================================================================
     SECTION HEADER  (kicker + Fraunces H2 + short intro, left-aligned)
     ========================================================================= */
  .sec-head {
    margin: 0 0 var(--space-7);
    max-width: 65ch;
  }

  /* Small uppercase eyebrow keeping the numbered-story feel. The number is mono;
     a forest middot separator (CSS ::before on .kicker__sep) sits between number
     and label, never a literal dash. */
  .kicker {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    margin: 0 0 var(--space-4);
    color: var(--accent);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: var(--lh-snug);
  }

  .kicker__num {
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  /* Forest middot separator. A real glyph inserted by CSS, not a dash. */
  .kicker__sep::before {
    content: '\00B7';
    color: var(--accent);
  }

  .sec-head__intro {
    margin: var(--space-5) 0 0;
    color: var(--text);
    font-size: var(--text-base);
    line-height: var(--lh-body);
    max-width: 66ch;
    text-wrap: pretty;
  }

  /* =========================================================================
     SHARED TYPE ROLES
     global.css forces h1 to Fraunces and h2..h6 to Inter. The headers want
     Fraunces for the H2 section titles and the pull quote, so each explicitly
     re-declares the display family to override the global Inter rule.
     ========================================================================= */
  .section-h2 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-h2-dossier);
    line-height: var(--lh-heading);
    letter-spacing: -0.01em;
    color: var(--text);
    max-width: 24ch;
    text-wrap: balance;
  }

  .section-h2--lead {
    max-width: 26ch;
  }

  .prose {
    color: var(--text);
    font-size: var(--text-base);
    line-height: var(--lh-body);
  }

  .prose p {
    margin: 0 0 var(--space-5);
    max-width: 65ch;
    text-wrap: pretty;
  }

  .prose p:last-child {
    margin-bottom: 0;
  }

  .prose--single {
    max-width: 65ch;
    text-wrap: pretty;
  }

  /* Prose that lives inside a FeatureRow column fills the column width (the
     column itself is already ~half the container), so the measure cap is removed
     and the text balances against the paired figure. */
  .feature-prose {
    max-width: none;
  }

  .feature-prose.prose p {
    max-width: none;
