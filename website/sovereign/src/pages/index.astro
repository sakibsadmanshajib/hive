  }

  .cta--ghost {
    background-color: transparent;
    color: var(--text);
    border: 1px solid var(--border-strong);
  }

  .cta--ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-1px);
  }

  /* Visible keyboard focus on every CTA, on the dark canvas. */
  .cta:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* On-ink primary: off-white fill, ink label (17.66:1). */
  .cta--on-ink {
    background-color: var(--on-ink);
    color: var(--ink);
    border: 1px solid var(--on-ink);
  }

  .cta--on-ink:hover {
    background-color: #ffffff;
    border-color: #ffffff;
    transform: translateY(-1px);
  }

  /* On-ink ghost: off-white hairline border, off-white label. */
  .cta--ghost-ink {
    background-color: transparent;
    color: var(--on-ink);
    border: 1px solid var(--on-ink-border);
  }

  .cta--ghost-ink:hover {
    border-color: var(--on-ink);
    transform: translateY(-1px);
  }

  /* =========================================================================
     CARDS  (almost flat; one restrained hover-raise, no layout shift)
     ========================================================================= */
  .cards {
    list-style: none;
    margin: var(--space-8) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-5);
  }

  .cards--3 {
    grid-template-columns: repeat(3, 1fr);
  }

  /* =========================================================================
     CAROUSEL  (section 05 audience cards, CSS-only scroll-snap, zero JS)

     RIGHT-ONLY BLEED. The .carousel-wrap sits inside .shell, so its LEFT edge
     already aligns with the section header, intro, and the trailing link. We keep
     that left edge fixed and extend only the RIGHT edge out to the viewport edge,
     so the next card peeks. We do NOT centre or use a 100vw transform (that
     misaligns the left edge and, because 100vw ignores the scrollbar, causes
     horizontal page overflow on mobile).

     The right bleed distance = the gap from the container right edge to the
     viewport right edge. That equals the shell side margin when the viewport
     exceeds --max-width, plus the shell's 24px inline padding, clamped to never
     go negative on narrow screens:
       --carousel-bleed-right: calc(max(0px, (100vw - var(--max-width)) / 2) + 24px)
     We then pull the scroller right by that amount with a negative right margin.

     The .carousel-wrap is set to overflow-x: clip so any sub-pixel rounding from
     the bleed can never produce a horizontal PAGE scrollbar. The card track keeps
     its own overflow-x: auto for the actual horizontal scroll.

     At >=1100px roughly 3 cards show with the next peeking. Scrollbar hidden;
     drag and keyboard scroll remain. Reduced-motion: no smooth.
     ========================================================================= */
  .carousel-wrap {
    position: relative;
    isolation: isolate;
    margin-top: var(--space-8);
    /* Right-only bleed: extend the wrap's right edge to the viewport edge.
       max(0px, ...) keeps this 0 below --max-width so narrow screens never
       gain extra width. The +24px is the shell inline padding. */
    --carousel-bleed-right: calc(max(0px, (100vw - var(--max-width)) / 2) + 24px);
    margin-right: calc(-1 * var(--carousel-bleed-right));
    /* Guard: clip any sub-pixel bleed so the page never scrolls sideways. */
    overflow-x: clip;
    /* Cap the wrap box at its container width so 100vw scrollbar gutter math
       can never widen the page itself; the inner track still scrolls. */
    max-width: 100%;
  }

  .cards--carousel {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    gap: var(--space-5);
    list-style: none;
    margin: 0;
    /* Left padding 0 (left edge aligns to container); right padding is the
       bleed distance so the last card can rest clear of the viewport edge. */
    padding: 0 var(--carousel-bleed-right) 0 0;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    /* Hide scrollbar visually; drag and keyboard scroll remain */
    scrollbar-width: none;
    align-items: stretch;
    box-sizing: border-box;
  }

  .cards--carousel::-webkit-scrollbar {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .cards--carousel {
      scroll-behavior: auto;
    }
  }

  .cards--carousel > li {
    flex: 0 0 auto;
    width: clamp(260px, 80vw, 330px);
    scroll-snap-align: start;
    display: flex;
  }

  /* On wider viewports show ~3 cards with the next card peeking */
  @media (min-width: 1100px) {
    .cards--carousel > li {
      width: clamp(280px, 22vw, 310px);
    }
  }

  @media (min-width: 900px) and (max-width: 1099px) {
    .cards--carousel > li {
      width: clamp(260px, 26vw, 300px);
    }
  }

  /* Equalize card heading height so short headings ("Legal.") and long ones
     ("Healthcare and health-data custodians.") do not make cards ragged. */
  .cards--carousel .card__h3 {
    min-height: 3.6em;
  }

  /* Right-edge fade affordance: sits at the true right edge of the wrap
     (the viewport edge), scoped to the carousel region. */
  .carousel-wrap::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 80px;
    height: 100%;
    background: linear-gradient(to right, transparent, var(--bg) 90%);
    pointer-events: none;
    z-index: 2;
  }

  .card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    padding: var(--space-6);
    transition: box-shadow var(--dur-base) var(--ease-out),
                transform var(--dur-base) var(--ease-out),
                border-color var(--dur-base) var(--ease-out);
  }

  .card:hover {
    box-shadow: var(--shadow-raise);
    transform: translateY(-2px);
    border-color: var(--border-strong);
  }

  /* Link cards (tier + audience): the whole card is a real anchor. The clickable
     hover-raise is earned because the card navigates. Reset link chrome so the
     card reads as content, not a blue link, and give keyboard users a visible
     focus ring. */
  .card--link {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
    text-decoration: none;
  }

  .card--link:hover {
    box-shadow: var(--shadow-raise);
    transform: translateY(-2px);
    border-color: var(--border-strong);
  }

  .card--link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Static cards (the control cards): informational only, never navigate. Drop
     the clickable affordance so they do not imply interactivity. Quiet hairline
     content, no hover-raise, no shadow, no border shift. */
  .card--static:hover {
    box-shadow: none;
    transform: none;
    border-color: var(--border);
  }

  .card__h3 {
    margin: 0 0 var(--space-3);
    font-size: var(--text-h3);
    line-height: var(--lh-heading);
    color: var(--text);
    text-wrap: balance;
  }

  .card__body {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-base);
    line-height: var(--lh-snug);
    text-wrap: pretty;
  }

  /* =========================================================================
     DIAGRAM COLOUR HOOKS (consumed by the SVGs inside Figure.astro)
     The SVG assets ship with inline fill/stroke hex baked for the OLD light
     theme (white surfaces, ink line-work). On dark those invert wrongly, so
     these :global CSS hooks REMAP every hooked element for the dark canvas.
     CSS presentation properties win over the SVG's inline presentation
     attributes (lower specificity), so the dark palette below takes effect:
       line-work / strokes -> light hairline (#cdd3db via currentColor + d-faint)
       surfaces            -> dark raised (var(--bg-elevated))
       grey fills          -> mid (var(--grey))
       muted text          -> light-muted (var(--text-muted))
       accent              -> brighter forest (var(--accent))
     Red (residency risk) stays red, tuned for dark. The text/strokes that paint
     with currentColor inherit .diagram { color } below, so they read as light
     line-work instead of near-black ink.
     ========================================================================= */
  /* Plain (unclassed) line-work and text paint with currentColor, so set the
     diagram's currentColor to a light hairline. Classed elements (d-muted,
     d-accent, d-risk-text, ...) override with their own fill below. */
  :global(.fig__svg .diagram) {
    color: #cdd3db;
  }
  :global(.fig__svg .diagram text) {
    font-family: var(--font-sans);
  }
  :global(.fig__svg .d-faint) {
    stroke: var(--border-strong);
  }
  :global(.fig__svg .d-axis) {
    stroke: var(--border-strong);
  }
  :global(.fig__svg .d-muted) {
    fill: var(--text-muted);
  }
  :global(.fig__svg .d-grey) {
    stroke: var(--grey);
    fill: var(--grey);
  }
  /* hosted-model box on the right path of the boundary diagram: dark raised
     surface with a grey outline (the SVG ships a bare white fill for the old
     light theme, which must be overridden to a dark surface here). */
  :global(.fig__svg .d-grey-stroke) {
    fill: var(--bg-elevated);
    stroke: var(--grey);
  }
  :global(.fig__svg .d-accent) {
    stroke: var(--accent);
    fill: var(--accent);
  }
  :global(.fig__svg .d-accent-line),
  :global(.fig__svg .d-accent-ring),
  :global(.fig__svg .d-accent-dash) {
    stroke: var(--accent);
  }
  :global(.fig__svg .d-accent-text) {
    fill: var(--accent);
  }
  /* burden series (tier-spectrum cost-of-control) reads as muted mid on dark */
  :global(.fig__svg .d-burden) {
    fill: var(--grey);
    stroke: var(--grey);
  }
  /* dark raised surface for boxes/plates inside the diagrams */
  :global(.fig__svg .d-surface) {
    fill: var(--bg-elevated);
  }
  /* Residency-risk red lives only inside the data-boundary diagram. */
  :global(.fig__svg .d-risk) {
    stroke: var(--risk);
    fill: var(--risk);
  }
  :global(.fig__svg .d-risk-text) {
    fill: var(--risk);
  }
  :global(.fig__svg .d-num) {
    font-family: var(--font-mono);
  }

  /* =========================================================================
     HERO  (2-column grid on desktop, single column on mobile)
     Desktop (>=900px): left col ~48% text, right col ~52% image.
     Image: full natural 16:9, never cropped, vertically centred.
     No border/shadow/card frame around the image.
     The hero bottom border separates it from the TrustStrip (ink surface) below.
     ========================================================================= */
  .hero {
    position: relative;
    overflow-x: clip;
    background-color: var(--bg);
    padding-top: var(--space-9);
    padding-bottom: 0;
    border-bottom: 1px solid var(--border);
  }

  /* 2-col grid lives inside .shell so it inherits the shell's horizontal padding */
  .hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
  }

  @media (min-width: 900px) {
    .hero__grid {
      grid-template-columns: 48fr 52fr;
      gap: var(--space-8);
      padding-bottom: var(--space-9);
    }
  }

  .hero__col {
    position: relative;
    z-index: 2;
    padding-bottom: var(--space-8);
  }

  @media (min-width: 900px) {
    .hero__col {
      padding-bottom: 0;
    }
  }

  .hero__imgcol {
    display: flex;
    align-items: center;
    justify-content: center;
    /* On mobile the image sits below the text with a small bottom pad */
    padding-bottom: var(--space-6);
  }

  @media (min-width: 900px) {
    .hero__imgcol {
      padding-bottom: 0;
      align-self: center;
    }
  }

  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border-strong);
  }

  .hero__tag {
    color: var(--text-muted);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero__metasep {
    color: var(--text-faint);
  }

  .hero__h1 {
    margin: var(--space-6) 0 0;
    color: var(--text);
    font-size: clamp(46px, 6.2vw, 80px);
    line-height: var(--lh-tight);
    letter-spacing: -0.02em;
