  @media (prefers-reduced-motion: no-preference) {
    .load-rise {
      animation: load-rise var(--dur-reveal) var(--ease-out) both;
    }
    .load-rise > * {
      animation: load-rise var(--dur-reveal) var(--ease-out) both;
    }
    .load-rise > *:nth-child(1) { animation-delay: 40ms; }
    .load-rise > *:nth-child(2) { animation-delay: 110ms; }
    .load-rise > *:nth-child(3) { animation-delay: 180ms; }
    .load-rise > *:nth-child(4) { animation-delay: 250ms; }
    .load-rise > *:nth-child(5) { animation-delay: 320ms; }
    .load-rise > *:nth-child(6) { animation-delay: 390ms; }

    .load-fade {
      animation: load-fade var(--dur-reveal) var(--ease-out) 120ms both;
    }
  }

  /* Entrance shifts position and fades from near-full opacity. Because the
     start opacity is high (0.6) and there is no persistent opacity:0 state,
     content is never hidden if the animation does not run. */
  @keyframes load-rise {
    from {
      transform: translateY(var(--reveal-shift));
      opacity: 0.6;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

