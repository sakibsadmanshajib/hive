  }

  /* =========================================================================
     CTA BUTTONS
     Base buttons live on off-white. The closing section is ink, so it gets
     two ink-legible variants (verified: off-white on accent = 11.65:1,
     ink on off-white fill = 17.66:1, off-white ghost border passes).
     ========================================================================= */
  .cta-row {
