---
// Pricing page (template: pricing, scope: both).
//
// Art direction: the confidential institutional dossier established by the Home
// page. A single .hero (one h1, single editorial column), then numbered
// SectionShell sections separated only by full-width hairline rules and spacing,
// content at a comfortable reading measure, full-width children opting out via
// .ds__bleed. One deliberate dark surface, the closing CTA band. Warm off-white
// base, single deep forest accent, near-black ink.
//
// Claim guardrail: no exact dollar figure appears in any heading; "low
// thousands" and "workstation-class box" are the only headline cost framing.
// Exact hardware prices appear only as small muted .card__note lines, never as
// a prominent price and never bolder than body text. No banned cost multiple.
// Pinterest is permitted here (cost section) with its results-vary disclaimer
// and date stamp. Hive Cloud carries no sovereignty or residency claim.
// LEGAL-REVIEW markers are invisible Astro comments only.
//
// Zero client JS, no script tags. The TCO chart is a STATIC inline SVG (no
// Recharts island, no empty-box failure), authored in the same visual language
// as src/assets/diagrams/cost-crossover.svg and inlined through Figure. The
// breakeven marker sits at the exact geometric intersection of the metered
// cloud line and the owned flat leg, computed below, not eyeballed.
//
//   Cloud line runs from (80,340) to (680,96), giving y = 340 minus
//     (244/600)(x minus 80).
//   Owned line steps up to (80,300), knees at (120,298.9), then runs a near-flat
//     leg to (680,252).
//   The x-axis maps month 0 to x=80 and month 36 to x=680 (16.667 px per month),
//     so month 7 is x=197. The two lines intersect there at y=292, which is where
//     the breakeven marker sits, so the visual crossover matches its month-7 label.
//   After the crossover the owned line (y=252 at x=680) sits visibly below the
//   cloud line (y=96 at x=680), so owning costs less past breakeven.
import Base from '../layouts/Base.astro';
import SectionShell from '../components/SectionShell.astro';
import Figure from '../components/Figure.astro';
import CalloutCard from '../components/charts/CalloutCard.astro';

// Static TCO crossover, authored in the cost-crossover.svg visual language. No
// exact dollars on the chart face; month ticks (0, 12, 24, 36) are units of
// time, not currency, and are allowed. Colours ride the .d-* host hooks: grey
// metered cloud, forest owned line, forest breakeven marker.
const tcoSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 420" role="img" aria-labelledby="tco-title tco-desc" fill="none" class="diagram diagram--crossover">
  <title id="tco-title">36-month cost: owned box versus metered API</title>
  <desc id="tco-desc">A line chart over 36 months. A grey metered-cloud line climbs steadily and never stops. A forest owned-hardware line steps up once for the box then stays nearly flat. The two lines cross at a marked breakeven, after which the owned line stays below the cloud line.</desc>

  <g class="d-faint" stroke="#e4e2dc" stroke-width="1">
    <line x1="80" y1="120" x2="680" y2="120" />
    <line x1="80" y1="190" x2="680" y2="190" />
    <line x1="80" y1="260" x2="680" y2="260" />
  </g>

  <g class="d-axis" stroke="#d4d1c9" stroke-width="1.5">
    <line x1="80" y1="60" x2="80" y2="340" />
    <line x1="80" y1="340" x2="680" y2="340" />
  </g>

  <g font-size="11" fill="#6b7585" class="d-muted" text-anchor="middle">
    <text x="80" y="358">0</text>
    <text x="280" y="358">12</text>
    <text x="480" y="358">24</text>
    <text x="680" y="358">36</text>
  </g>
  <text x="80" y="378" text-anchor="start" font-size="12" fill="#6b7585" class="d-muted">Months</text>
  <text x="680" y="378" text-anchor="end" font-size="12" fill="#6b7585" class="d-muted" font-style="italic">the meter never stops</text>
  <g transform="translate(40 200) rotate(-90 0 0)">
    <text x="0" y="0" text-anchor="middle" font-size="12" fill="#6b7585" class="d-muted">Cumulative cost</text>
  </g>

  <path class="d-grey" d="M80 340 L680 96" stroke="#6b7585" stroke-width="2.25" />
  <circle class="d-grey-dot" cx="680" cy="96" r="3.5" fill="#6b7585" />

  <path class="d-accent-line" d="M80 340 L80 300 L120 298.9 L680 252" stroke="#0d3b2e" stroke-width="2.5" fill="none" />
  <g class="d-accent" fill="#0d3b2e">
    <circle cx="80" cy="300" r="3.5" />
  </g>
  <text x="92" y="294" font-size="11" fill="#6b7585" class="d-muted">Upfront, the box you own</text>

  <g class="d-cross">
    <line x1="197" y1="292" x2="197" y2="340" stroke="#0d3b2e" stroke-width="1" stroke-dasharray="2 4" opacity="0.5" class="d-accent-dash" />
    <circle cx="197" cy="292" r="6" fill="#f8f7f4" stroke="#0d3b2e" stroke-width="2" class="d-accent-ring" />
    <circle cx="197" cy="292" r="2" fill="#0d3b2e" class="d-accent" />
    <text x="206" y="283" font-size="12.5" font-weight="600" fill="#0d3b2e" class="d-accent-text">Breakeven</text>
    <text x="206" y="301" font-size="11" fill="#6b7585" class="d-muted">&#8776; month 7, after this owning costs less</text>
  </g>

  <g font-size="12.5" font-weight="600">
    <text x="560" y="118" fill="#6b7585" class="d-muted">Metered cloud</text>
    <text x="500" y="244" fill="#0d3b2e" class="d-accent-text">Owned hardware</text>
  </g>
</svg>`;
---

<Base
  title="On-Premises AI Pricing: Own vs Rent"
  description="Buy a workstation-class box you own in the low thousands, with an annual licence. Or start on Hive Cloud at a fraction of typical hosted-API pricing. For sustained daily work, owning is the cheaper position over time."
  structuredData={{
    breadcrumbs: [
      { name: 'Home', url: 'https://hive.scubed.co/' },
      { name: 'Pricing', url: 'https://hive.scubed.co/pricing' },
    ],
    pricingFaq: true,
    service: true,
  }}
>
  {/* ============ HERO (single editorial column, the only h1) ============ */}
  <section class="hero" aria-labelledby="hero-h1">
    <div class="shell">
      <div class="hero__col load-rise">
        <p class="hero__meta">
          <span class="hero__tag">Pricing</span>
          <span class="hero__metasep" aria-hidden="true">&#183;</span>
          <span class="hero__tag">Own it</span>
          <span class="hero__metasep" aria-hidden="true">&#183;</span>
          <span class="hero__tag">Cost</span>
        </p>
        <h1 id="hero-h1" class="hero__h1">
          Buy a workstation-class box you own. Stop renting a meter that never
          stops.
        </h1>
        <p class="lede">
          A third-party AI API charges you per token, and the bill grows with
          use. An open-weight model you own is a mostly fixed cost up front, then
          inference is roughly electricity. For sustained daily work, owning is
          the cheaper position over time.
        </p>
        <div class="cta-row">
          <a class="cta cta--primary tap-target" href="/book-a-demo">Book a Demo</a>
          <a class="cta cta--ghost tap-target" href="/book-a-demo">Talk to us about your workload</a>
        </div>
      </div>
    </div>
  </section>

  {/* ============ 01 TWO COST SHAPES ============ */}
  <SectionShell numeral="01" label="Two cost shapes" id="shapes-h2">
    <h2 class="section-h2 section-h2--lead">
      A rented meter compounds. An owned box settles.
    </h2>
    <div class="prose">
      <p>
        The two models behave in opposite ways over time. A metered API starts
        near zero and rises with use, and it rises fastest exactly when AI is
        working hardest for you. An owned box costs more on day one and then
        flattens, because once the hardware is paid for, running inference on it
        is close to the cost of the power it draws.
      </p>
      <p>
        So the answer depends on how you use AI. For light, occasional, bursty
        use, a public API is cheap and convenient and there is no reason to own
        anything. For long-running agents, automations, and sustained heavy
        daily usage, the metered bill overtakes the owned box and keeps going,
        while the owned box keeps saving.
        {/* LEGAL-REVIEW */}
      </p>
    </div>
  </SectionShell>

  {/* ============ 02 WHERE OWNERSHIP OVERTAKES RENTING ============ */}
  <SectionShell numeral="02" label="Where ownership overtakes renting" id="crossover">
    <h2 class="section-h2 section-h2--lead">
      The entry box pays for itself in about seven months, then keeps saving.
    </h2>
    <div class="prose">
      <p>
        Picture the two costs as lines over time. The metered API line starts
        low and rises with every token. The owned box line starts higher, at the
        price of the hardware, then barely moves. Early on, renting looks
        cheaper. Then the two lines cross, and from that point the owned box is
        ahead and the gap widens every month.
      </p>
      <p>
        For the entry-tier box on a sustained workload, that crossover lands at
        about month seven. After that, every month is money the metered API
        would still be charging and the box no longer is. Measured on output,
        open-weight inference runs roughly
        <span class="font-mono" data-numeric>10x</span> to
        <span class="font-mono" data-numeric>30x</span> cheaper than the
        proprietary APIs, which is why the box settles so quickly.
      </p>
    </div>

    <div class="ds__bleed cost__faceline">
      <span class="cost__facefig font-mono" data-numeric>~10x to ~30x</span>
      <span class="cost__facelabel">cheaper on output than proprietary APIs</span>
    </div>

    <div class="ds__bleed">
      <Figure
        fig="Fig. 1"
        svg={tcoSvg}
        caption="36-month cost: the owned box is a near-flat line, the metered API climbs the whole way. They cross at about month seven for the entry box."
        ariaLabel="A line chart over 36 months. A grey metered-cloud line climbs steadily and never stops. A forest owned-hardware line steps up once for the box then stays nearly flat. The two lines cross at a marked breakeven near month seven, after which the owned line stays below the cloud line."
      />
    </div>

    <p class="footnote">
      Assumes 10M output tokens per month. Power-only opex, excludes labour.
      Hardware prices approx. June 2026.
    </p>
    <p class="footnote">
      Modelled 36-month TCO. Strix payback approx month 7, DGX payback approx
      month 17. Rates as of June 2026. Hosted-API pricing, self-hosting
      economics differ.
    </p>
  </SectionShell>

  {/* ============ 03 THE ON-PREM LADDER ============ */}
  <SectionShell numeral="03" label="The on-prem ladder" id="ladder-h2">
    <h2 class="section-h2 section-h2--lead">
      Start with one box. Add compute and nodes as you grow.
    </h2>
    <p class="prose prose--single">
      On-prem pricing has three moving parts: the box itself, the compute you add
      to it, and the nodes you scale out to. You start where your workload is
      today and step up only when load demands it. The integration does not
      change as you climb the ladder, so each step builds on the last instead of
      replacing it.
    </p>

    <ul class="ds__bleed cards cards--4" role="list">
      <li class="card card--static">
        <h3 class="card__h3">The entry box</h3>
        <p class="card__body">
          A workstation-class box you own, in the low thousands. It is sized for
          a small regulated firm running real daily work, and it is the box that
          pays for itself in about seven months on a sustained workload.
        </p>
        <p class="card__note">
          <span data-numeric>AMD Strix Halo 128GB class, starts under $2,000, approx June 2026, rising.</span>
        </p>
      </li>
      <li class="card card--static">
        <h3 class="card__h3">The step-up box</h3>
        <p class="card__body">
          A higher-throughput box for heavier workloads, still hardware you own.
        </p>
        <p class="card__note">
          <span data-numeric>NVIDIA DGX Spark, approx $4,699, approx June 2026, rising.</span>
        </p>
      </li>
      <li class="card card--static">
        <h3 class="card__h3">Compute add-on</h3>
        <p class="card__body">
          Add GPU capacity to a box as your throughput needs grow, without
          changing your integration. Priced per unit of compute added. Talk to
          us for a figure sized to your workload.
        </p>
      </li>
      <li class="card card--static">
        <h3 class="card__h3">Per-node scale-out</h3>
        <p class="card__body">
          When one box is not enough, scale to multiple nodes. Priced per node,
          so cost tracks capacity. Talk to us for a figure sized to your
          deployment.
        </p>
      </li>
    </ul>
  </SectionShell>

  {/* ============ 04 WHAT THE LICENCE COVERS ============ */}
  <SectionShell numeral="04" label="What the licence covers" id="licence-h2">
    <h2 class="section-h2 section-h2--lead">
      Software, updates, new-model compatibility, and support, on a yearly
      licence.
    </h2>
    <div class="prose">
      <p>
        On top of the hardware, an annual Hive licence keeps the software current
        and supported. It covers ongoing software updates, compatibility with
        new open-weight models as they ship so your box runs newer and stronger
        models over time, and direct support from the team that builds it. The
        hardware is a one-time purchase you own. The licence is the yearly cost
        of keeping it current and supported, so the box you bought keeps
        improving rather than ageing out.
      </p>
    </div>
  </SectionShell>

  {/* ============ 05 HIVE CLOUD (no sovereignty or residency claim here) ============ */}
  <SectionShell numeral="05" label="Hive Cloud" id="cloud-h2">
    <h2 class="section-h2 section-h2--lead">
      Not ready to own hardware yet? Start on Hive Cloud.
    </h2>
    <div class="prose">
      <p>
        If you are not ready to buy a box, Hive Cloud runs the same software on a
        hosted, region-locked instance at a fraction of typical hosted-API
        pricing. It is the fastest way to start and the lowest up-front cost.
        Talk to us for a figure sized to your usage.
      </p>
    </div>
  </SectionShell>

  {/* ============ 06 PROOF FROM THE FIELD (Pinterest, cost section) ============ */}
  <SectionShell numeral="06" label="Proof from the field" id="proof-h2">
    <div class="cost__proof">
      <CalloutCard
        accent="teal"
        statement="Pinterest cut AI costs roughly 90 percent and raised accuracy roughly 30 percent by running and customising the open-weight Qwen3-VL model on its own infrastructure."
        asOf="as of June 2026"
      >
        <p slot="disclaimer" class="callout-disclaimer">
          Results reflect Pinterest's specific implementation. Your outcomes
          will depend on your hardware, model choice, and workload.
        </p>
      </CalloutCard>
    </div>
  </SectionShell>

  {/* ============ 07 DISCLAIMER (verbatim) ============ */}
  <SectionShell numeral="07" label="Disclaimer" id="disclaimer-h2">
    <p class="disclaimer" role="note">
      On-prem pricing covers software licensing and support. Hardware
      procurement, security hardening, and regulatory validation are the
      customer's responsibility. Hive Cloud deployments run on third-party
      infrastructure and do not carry the same data-residency properties as the
      on-prem edition.
    </p>
  </SectionShell>

  {/* ============ 08 FAQ ============ */}
  <SectionShell numeral="08" label="Common questions" id="faq-h2">
    <h2 class="section-h2 section-h2--lead">
      Frequently asked questions
    </h2>
    <div class="faq">
      <details class="faq__item">
        <summary class="faq__q">How long does an on-prem Hive box take to pay for itself?</summary>
        <p class="faq__a">
          It depends on your inference volume. The model on this page shows
          the breakeven point where the owned box passes metered cloud.
        </p>
      </details>
      <details class="faq__item">
        <summary class="faq__q">What is included in the annual Hive licence?</summary>
        <p class="faq__a">
          Continuous software updates, validation and availability of new
          supported open-weight models, and the platform that runs them on
          your hardware.
        </p>
      </details>
    </div>
  </SectionShell>

  {/* ============ CLOSING CTA (ink, the one deliberate dark surface) ============ */}
  <section class="closing" aria-labelledby="closing-h2">
    <div class="shell narrow closing__inner">
      <h2 id="closing-h2" class="section-h2 section-h2--lead closing__h2">
        Tell us your workload. We will tell you what it costs to own it.
      </h2>
      <div class="cta-row">
        <a class="cta cta--on-ink tap-target" href="/book-a-demo">Book a Demo</a>
        <a class="cta cta--ghost-ink tap-target" href="/how-you-run-hive">See how you run Hive</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* =========================================================================
     SHARED TYPE ROLES (dossier kit, copied verbatim from the Home page).
     global.css forces h2..h6 to Inter; .section-h2 re-declares the display
     family so the dossier H2 titles stay Fraunces.
     ========================================================================= */
  .section-h2 {
    margin: 0 0 var(--space-6);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-h2-dossier);
    line-height: var(--lh-heading);
    letter-spacing: -0.01em;
    color: var(--text);
    max-width: 22ch;
  }

  .section-h2--lead {
    max-width: 24ch;
  }

  .prose {
    color: var(--text);
    font-size: var(--text-base);
    line-height: var(--lh-body);
  }

  .prose p {
    margin: 0 0 var(--space-5);
    max-width: 68ch;
  }

  .prose p:last-child {
    margin-bottom: 0;
  }

  .prose--single {
    margin: var(--space-5) 0 0;
    max-width: 66ch;
  }

  .prose__after {
    margin: var(--space-7) 0 0;
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: var(--lh-body);
    max-width: 68ch;
  }

  .textlink {
    color: var(--accent);
    font-weight: 600;
    border-bottom: 1px solid var(--accent-line);
    padding-bottom: 1px;
    transition: border-color var(--dur-fast) var(--ease-out);
  }

  .textlink:hover {
    border-bottom-color: var(--accent);
  }

  .narrow {
    max-width: 800px;
  }

  /* =========================================================================
     CTA BUTTONS (dossier kit, verbatim). The contrast-safe primary is forest
     fill with an off-white label; the closing band carries the ink variants.
     ========================================================================= */
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-7);
  }

  .cta {
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.01em;
    padding: 14px 26px;
    border-radius: var(--radius-sm);
    transition: background-color var(--dur-base) var(--ease-out),
                border-color var(--dur-base) var(--ease-out),
                transform var(--dur-base) var(--ease-out);
  }

  .cta--primary {
    background-color: var(--accent);
    color: var(--bg);
    border: 1px solid var(--accent);
  }

  .cta--primary:hover {
    background-color: var(--accent-hover);
    border-color: var(--accent-hover);
    transform: translateY(-1px);
  }

  .cta--ghost {
    background-color: transparent;
    color: var(--text);
    border: 1px solid var(--border-strong);
  }

  .cta--ghost:hover {
    border-color: var(--text-faint);
    transform: translateY(-1px);
  }

  .cta--on-ink {
    background-color: var(--on-ink);
    color: var(--ink);
    border: 1px solid var(--on-ink);
  }

  .cta--on-ink:hover {
    background-color: #ffffff;
    border-color: #ffffff;
    transform: translateY(-1px);
  }

  .cta--ghost-ink {
    background-color: transparent;
    color: var(--on-ink);
    border: 1px solid var(--on-ink-border);
  }

  .cta--ghost-ink:hover {
    border-color: var(--on-ink);
    transform: translateY(-1px);
  }

  /* =========================================================================
     CARDS (dossier kit, verbatim). The ladder uses the four-up grid.
     ========================================================================= */
  .cards {
    list-style: none;
    margin: var(--space-8) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-5);
  }

  .cards--3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .cards--4 {
    grid-template-columns: repeat(2, 1fr);
  }

  .card {
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    padding: var(--space-6);
    transition: box-shadow var(--dur-base) var(--ease-out),
                transform var(--dur-base) var(--ease-out),
                border-color var(--dur-base) var(--ease-out);
  }

  .card:hover {
    box-shadow: var(--shadow-raise);
    transform: translateY(-2px);
    border-color: var(--border-strong);
  }

  /* Static cards: informational only, never navigate. Drop the clickable
     hover-raise so they do not imply interactivity. */
  .card--static:hover {
    box-shadow: none;
    transform: none;
    border-color: var(--border);
  }

  .card__h3 {
    margin: 0 0 var(--space-3);
    font-size: var(--text-h3);
    line-height: var(--lh-heading);
    color: var(--text);
  }

  .card__body {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-base);
    line-height: var(--lh-snug);
  }

  /* Footnote-grade hardware note. Never a price headline: muted, small, never
     bolder or larger than body text. This is the only place exact dollars live
     in the ladder, so the low-thousands headline framing stays consistent. */
  .card__note {
    margin: var(--space-4) 0 0;
    color: var(--text-faint);
    font-size: var(--text-sm);
    line-height: var(--lh-snug);
  }

  /* =========================================================================
     COST (on-face figure callout + footnotes, dossier kit verbatim)
     ========================================================================= */
  .cost__faceline {
    margin: var(--space-7) 0 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-6) var(--space-7);
    background-color: var(--accent-wash);
    border: 1px solid var(--accent-line);
    border-radius: var(--radius-card);
  }

  .cost__facefig {
    color: var(--accent);
    font-size: clamp(32px, 4.5vw, 48px);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .cost__facelabel {
    color: var(--text-muted);
    font-size: var(--text-md);
    line-height: var(--lh-snug);
  }

  .cost__proof {
    margin: var(--space-5) 0 0;
    max-width: 640px;
  }

  .callout-disclaimer {
    margin: 0;
    color: var(--text-faint);
    font-size: var(--text-xs);
    line-height: var(--lh-snug);
  }

  /* Small muted footnote rows below the chart (assumptions + citation). */
  .footnote {
    margin: var(--space-5) 0 0;
    color: var(--text-faint);
    font-size: var(--text-sm);
    line-height: var(--lh-snug);
    max-width: 78ch;
  }

  /* =========================================================================
     DISCLAIMER BLOCK
     ========================================================================= */
  .disclaimer {
    margin: 0;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-card);
    background-color: var(--bg-card);
    padding: var(--space-6);
    color: var(--text-muted);
    font-size: var(--text-base);
    line-height: var(--lh-body);
    max-width: 78ch;
  }

  /* =========================================================================
     DIAGRAM COLOUR HOOKS (consumed by the static TCO SVG inside Figure).
     Copied verbatim from the Home page. Remapped for the dark canvas: light
     hairline line-work, dark raised surfaces, brighter forest accent. No red
