---
// Callout card for a named proof point (Perplexity, Pinterest). Static, zero
// JS. The `asOf` line is mandatory framing (e.g. "as of January 2025"). The
// disclaimer slot carries the same-section qualifier where one is required
// (Pinterest).
//
// Placement is the caller's responsibility and is also enforced by the content
// lint: the Pinterest card may only appear in a cost-scoped section, never on
// the Security page and never adjacent to a sovereignty claim.
interface Props {
  // Visual accent. Proof points use teal; never red for a positive proof.
  accent?: 'teal' | 'gold';
  statement: string;
  asOf: string;
}

const { accent = 'teal', statement, asOf } = Astro.props;
const accentColor = accent === 'gold' ? 'var(--gold)' : 'var(--teal)';
---

<div class="callout" style={`--callout-accent: ${accentColor}`}>
  <p class="callout__statement">{statement}</p>
  <p class="callout__asof"><span data-numeric>{asOf}</span></p>
  <slot name="disclaimer" />
</div>

<style>
  .callout {
    border: 1px solid var(--border);
    border-left: 3px solid var(--callout-accent);
    border-radius: var(--radius);
    background-color: var(--bg-card);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .callout__statement {
    margin: 0;
    color: var(--text);
    font-size: 16px;
    line-height: 1.5;
  }
  .callout__asof {
    margin: 0;
    color: var(--text-faint);
    font-size: 12.5px;
  }
</style>
