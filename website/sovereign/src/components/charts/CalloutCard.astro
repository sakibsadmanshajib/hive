---
// Callout card for a named proof point (Perplexity, Pinterest). Static, zero
// JS. The `asOf` line is mandatory framing (e.g. "as of January 2025"). The
// disclaimer slot carries the same-section qualifier where one is required
// (Pinterest).
//
// Placement is the caller's responsibility and is also enforced by the content
// lint: the Pinterest card may only appear in a cost-scoped section, never on
// the Security page and never adjacent to a sovereignty claim.
//
// The accent is applied through a scoped class, never an inline style attribute,
// so it survives a strict Content-Security-Policy that forbids inline styles.
// Both legacy accent names resolve to the single deep-forest accent (var(--accent));
// there is no second hue on the site.
interface Props {
  // Visual accent. Kept for API compatibility; both values render the single
  // forest accent. Never red for a positive proof.
  accent?: 'teal' | 'gold';
  statement: string;
  asOf: string;
}

const { accent = 'teal', statement, asOf } = Astro.props;
// Class hook only; both accents map to the one forest accent in CSS below.
const accentClass = accent === 'gold' ? 'callout--gold' : 'callout--teal';
---

<div class:list={['callout', accentClass]}>
  <p class="callout__statement">{statement}</p>
  <p class="callout__asof"><span data-numeric>{asOf}</span></p>
  <slot name="disclaimer" />
</div>

<style>
  .callout {
    /* Single forest accent. No inline style, CSP-clean. */
    --callout-accent: var(--accent);
    border: 1px solid var(--border);
    border-left: 3px solid var(--callout-accent);
    border-radius: var(--radius);
    background-color: var(--bg-card);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  /* Both accent variants resolve to the one forest accent; kept as explicit
     hooks so the prop API stays meaningful without introducing a second hue. */
  .callout--teal,
  .callout--gold {
    --callout-accent: var(--accent);
  }
  .callout__statement {
    margin: 0;
    color: var(--text);
    font-size: 16px;
    line-height: 1.5;
  }
  .callout__asof {
    margin: 0;
    color: var(--text-faint);
    font-size: 12.5px;
  }
</style>
