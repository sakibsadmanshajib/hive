---
// Primary navigation. "Book a Demo" is the single gold call to action.
// All targets are at least 24px (WCAG 2.2 target size).
const links = [
  { href: '/', label: 'Home' },
  { href: '/how-you-run-hive', label: 'How You Run Hive' },
  { href: '/security', label: 'Security & Data Residency' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/use-cases', label: 'Use Cases' },
];

const path = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---

<nav class="nav" aria-label="Primary">
  <div class="shell nav__inner">
    <a class="nav__brand" href="/" aria-label="Hive home">
      <span class="nav__brand-mark" aria-hidden="true">
        <svg viewBox="0 0 64 64" width="20" height="20" focusable="false">
          <rect
            x="12"
            y="12"
            width="40"
            height="40"
            rx="10"
            fill="none"
            stroke="currentColor"
            stroke-width="5"></rect>
          <rect x="26" y="26" width="12" height="12" rx="3" fill="currentColor"
          ></rect>
        </svg>
      </span>
      Hive
    </a>

    <details class="nav__mobile">
      <summary class="nav__toggle" aria-label="Menu">
        <svg class="nav__toggle-icon" viewBox="0 0 24 24" width="22" height="22" fill="none" aria-hidden="true" focusable="false">
          <rect x="3" y="6" width="18" height="2" rx="1" fill="currentColor" />
          <rect x="3" y="11" width="18" height="2" rx="1" fill="currentColor" />
          <rect x="3" y="16" width="18" height="2" rx="1" fill="currentColor" />
        </svg>
      </summary>
      <ul class="nav__links">
        {
          links.map((link) => (
            <li>
              <a
                class="nav__link tap-target"
                href={link.href}
                aria-current={isActive(link.href) ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </details>

    <a class="nav__cta tap-target" href="/book-a-demo">Book a Demo</a>
  </div>
</nav>

<style>
  .nav {
    border-bottom: 1px solid var(--border);
    background-color: color-mix(in srgb, var(--bg) 88%, transparent);
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(8px);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    gap: 32px;
    min-height: 64px;
  }

  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    font-size: 18px;
    letter-spacing: -0.01em;
  }

  /* Concept 1 containment-vault mark, inlined so it themes via currentColor
     (forest accent on the off-white nav). */
  .nav__brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    color: var(--accent);
  }

  .nav__brand-mark svg {
    display: block;
    width: 20px;
    height: 20px;
  }

  /* =========================================================================
     MOBILE DISCLOSURE WRAPPER
     Desktop: details always treated as open via block layout; summary hidden.
     Mobile: native <details> open/close disclosure, links drop below nav bar.
     Zero JavaScript. CSP-safe.
     ========================================================================= */
  .nav__mobile {
    /* Desktop: participate in the flex row, push links to the right */
    display: contents;
  }

  /* Hide the toggle on desktop; the details content is always visible */
  .nav__toggle {
    display: none;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 24px;
    margin: 0;
    padding: 0;
    list-style: none;
    margin-inline-start: auto;
  }

  .nav__link {
    display: inline-flex;
    align-items: center;
    color: var(--text-muted);
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    border-bottom: 1px solid transparent;
    transition:
      color 120ms ease,
      border-color 120ms ease;
  }

  .nav__link:hover {
    color: var(--text);
    border-bottom-color: var(--accent);
  }

  .nav__link[aria-current='page'] {
    color: var(--text);
    border-bottom-color: var(--accent);
  }

  .nav__link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 4px;
  }

  .nav__cta {
    display: inline-flex;
    align-items: center;
    background-color: var(--accent);
    color: var(--on-accent);
    font-weight: 600;
    font-size: 15px;
    padding: 10px 18px;
    border-radius: 10px;
    cursor: pointer;
    transition:
      transform 120ms ease,
      background-color 120ms ease;
  }

  /* Subtle 1px lift on hover. transform only, so there is no layout shift. */
  .nav__cta:hover {
    transform: translateY(-1px);
    background-color: var(--accent-hover);
  }

  .nav__cta:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* =========================================================================
     MOBILE (<=760px): show hamburger toggle, collapse links into dropdown
     ========================================================================= */
  @media (max-width: 760px) {
    /* The sticky nav bar is the positioning context for the dropdown panel,
       so the panel can be pinned to both shell gutters and never overflow. */
    .nav {
      position: sticky;
    }

    /* details becomes a block container that holds the toggle on the right */
    .nav__mobile {
      display: block;
      margin-inline-start: auto;
      /* No position: relative here, so the absolute panel below resolves
         against the full-width .nav bar instead of this narrow box. */
    }

    /* Remove default marker */
    .nav__toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      list-style: none;
      width: 44px;
      height: 44px;
      border-radius: var(--radius-sm, 8px);
      color: var(--text);
      cursor: pointer;
      /* Visible focus ring for keyboard users */
    }

    .nav__toggle::-webkit-details-marker {
      display: none;
    }

    .nav__toggle:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    /* Links panel: hidden until details[open], then drops down. Resolves
       against the full-width sticky .nav bar and is pinned to both shell
       gutters (24px each side), so it always sits fully inside the viewport,
       the left edge can never go negative, and labels never clip. */
    .nav__links {
      display: none;
      position: absolute;
      inset-inline: 24px;
      top: 100%;
      margin-top: 8px;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: var(--space-3, 12px) 0;
      background-color: var(--bg-card, #fff);
      border: 1px solid var(--border);
      border-radius: var(--radius-card, 12px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
      z-index: 100;
    }

    .nav__mobile[open] .nav__links {
      display: flex;
    }

    .nav__links li {
      width: 100%;
    }

    .nav__link {
      display: flex;
      width: 100%;
      padding: 12px var(--space-5, 20px);
      font-size: 15px;
    }
  }
</style>
