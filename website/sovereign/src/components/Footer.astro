---
// Footer. Legal entity is "S Cubed". Country switcher links to ?geo=bd and
// ?geo=co; a Cloudflare Worker will turn those into redirects later. Here we
// only render the anchors.
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/security', label: 'Security & Data Residency' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/use-cases', label: 'Use Cases' },
  { href: '/book-a-demo', label: 'Book a Demo' },
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="shell footer__inner">
    <div class="footer__brand">
      <span class="footer__name">
        <span class="footer__mark" aria-hidden="true">
          <svg viewBox="0 0 64 64" width="20" height="20" focusable="false">
            <rect
              x="12"
              y="12"
              width="40"
              height="40"
              rx="10"
              fill="none"
              stroke="currentColor"
              stroke-width="5"></rect>
            <rect x="26" y="26" width="12" height="12" rx="3" fill="currentColor"
            ></rect>
          </svg>
        </span>
        S Cubed Technology Ltd.
      </span>
      <p class="footer__tagline">
        Your AI runs on your hardware. Your data never moves.
      </p>
    </div>

    <nav class="footer__nav" aria-label="Footer">
      <ul>
        {
          navLinks.map((link) => (
            <li>
              <a class="footer__link tap-target" href={link.href}>
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="footer__geo">
      <span class="footer__geo-label">Region</span>
      <ul>
        <li>
          <a class="footer__link tap-target" href="/?geo=co" hreflang="en">
            Global
          </a>
        </li>
        <li>
          <a class="footer__link tap-target" href="/?geo=bd" hreflang="en">
            Bangladesh
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="shell footer__legal">
    <span data-numeric>{year}</span> S Cubed Technology Ltd. All rights reserved.
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background-color: var(--bg-raised);
    padding-block: 56px 32px;
    margin-top: var(--section-rhythm);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 40px;
  }

  .footer__name {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    font-size: 16px;
  }

  /* Concept 1 containment-vault mark, inlined so it themes via currentColor
     (forest accent). */
  .footer__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    color: var(--accent);
  }

  .footer__mark svg {
    display: block;
    width: 20px;
    height: 20px;
  }

  .footer__tagline {
    color: var(--text-muted);
    font-size: 14px;
    margin-top: 10px;
    max-width: 30ch;
  }

  .footer__nav ul,
  .footer__geo ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer__geo-label {
    display: block;
    color: var(--text-faint);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
  }

  .footer__link {
    display: inline-flex;
    align-items: center;
    color: var(--text-muted);
    font-size: 14px;
    transition: color 120ms ease;
  }

  .footer__link:hover {
    color: var(--text);
  }

  .footer__legal {
    color: var(--text-faint);
    font-size: 13px;
    margin-top: 40px;
  }

  @media (max-width: 760px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
</style>
