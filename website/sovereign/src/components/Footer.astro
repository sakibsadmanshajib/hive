---
// Footer. Legal entity is "S Cubed Technology Ltd." Grouped link columns
// (Product, Company, Region) plus brand + tagline + copyright. The region
// switcher links to ?geo=bd and ?geo=co; a Cloudflare Worker will turn those
// into redirects later. Here we only render the anchors.
const product = [
  { href: '/how-you-run-hive', label: 'How You Run Hive' },
  { href: '/security', label: 'Security & Data Residency' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/use-cases', label: 'Use Cases' },
];

const company = [
  { href: '/', label: 'Home' },
  { href: '/book-a-demo', label: 'Book a Demo' },
  { href: 'mailto:hello@hive.scubed.co', label: 'Contact' },
];

const regions = [
  { href: '/?geo=co', label: 'Global', hreflang: 'en' },
  { href: '/?geo=bd', label: 'Bangladesh', hreflang: 'en' },
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="shell footer__inner">
    <div class="footer__brand">
      <span class="footer__name">
        <span class="footer__mark" aria-hidden="true">
          <svg viewBox="0 0 64 64" width="22" height="22" focusable="false">
            <rect
              x="12"
              y="12"
              width="40"
              height="40"
              rx="10"
              fill="none"
              stroke="currentColor"
              stroke-width="5"></rect>
            <rect x="26" y="26" width="12" height="12" rx="3" fill="currentColor"
            ></rect>
          </svg>
        </span>
        Hive
      </span>
      <p class="footer__tagline">
        Your AI runs on your hardware. Your data never moves. On-prem and
        in-region AI for organisations that cannot send their data to a
        third-party cloud.
      </p>
      <p class="footer__entity">S Cubed Technology Ltd.</p>
    </div>

    <nav class="footer__cols" aria-label="Footer">
      <div class="footer__col">
        <span class="footer__col-label">Product</span>
        <ul>
          {
            product.map((link) => (
              <li>
                <a class="footer__link tap-target" href={link.href}>
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer__col">
        <span class="footer__col-label">Company</span>
        <ul>
          {
            company.map((link) => (
              <li>
                <a class="footer__link tap-target" href={link.href}>
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer__col">
        <span class="footer__col-label">Region</span>
        <ul>
          {
            regions.map((link) => (
              <li>
                <a
                  class="footer__link tap-target"
                  href={link.href}
                  hreflang={link.hreflang}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </nav>
  </div>

  <div class="shell footer__legal">
    <span data-numeric>{year}</span> S Cubed Technology Ltd. All rights reserved.
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background-color: var(--bg-raised);
    padding-block: 56px 32px;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 40px;
  }

  .footer__name {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    font-size: 18px;
  }

  /* Concept 1 containment-vault mark, inlined so it themes via currentColor
     (forest accent). */
  .footer__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    color: var(--accent);
  }

  .footer__mark svg {
    display: block;
    width: 22px;
    height: 22px;
  }

  .footer__tagline {
    color: var(--text-muted);
    font-size: 14px;
    line-height: var(--lh-snug);
    margin-top: 14px;
    max-width: 42ch;
    text-wrap: pretty;
  }

  .footer__entity {
    color: var(--text-faint);
    font-size: 13px;
    margin-top: 16px;
  }

  .footer__cols {
    display: contents;
  }

  .footer__col-label {
    display: block;
    color: var(--text-faint);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 14px;
  }

  .footer__col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 11px;
  }

  .footer__link {
    display: inline-flex;
    align-items: center;
    color: var(--text-muted);
    font-size: 14px;
    cursor: pointer;
    border-bottom: 1px solid transparent;
    transition:
      color 120ms ease,
      border-color 120ms ease;
  }

  .footer__link:hover {
    color: var(--text);
    border-bottom-color: var(--accent);
  }

  .footer__link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 4px;
  }

  .footer__legal {
    color: var(--text-faint);
    font-size: 13px;
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 760px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }
    .footer__brand {
      grid-column: 1 / -1;
    }
  }
</style>
