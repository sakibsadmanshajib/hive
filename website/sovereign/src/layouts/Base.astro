---
// Base layout shell. Every page renders inside this.
//
// Accessibility:
//   - html lang="en"
//   - skip-link to #main
//   - gold focus ring (defined in global.css, contrast >= 3:1)
//   - prefers-reduced-motion honoured globally (global.css)
//   - interactive targets >= 24px (tap-target utility)
//
// Performance:
//   - only Fraunces 600 and Inter 400 are preloaded. Other weights load on
//     demand via Fontsource @font-face (font-display: swap).
//
// Background:
//   - a faint hex-lattice motif at ~4% opacity, NOT the BD honeycomb.
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StructuredData from '../components/StructuredData.astro';
import '../styles/global.css';

// Self-hosted fonts live in public/fonts and are served from the same origin.
// Preload only the two used above the fold (Fraunces 600 + Inter 400). The
// other weights load on demand via the @font-face rules in global.css.
const fraunces600 = '/fonts/fraunces-latin-600-normal.woff2';
const inter400 = '/fonts/inter-latin-400-normal.woff2';

interface Props {
  title: string;
  description: string;
  /* Optional, site-root-relative path to a social card (e.g. /og/foo.png).
     Defaults to /og/default.png. Resolved to an absolute URL below. */
  image?: string;
  /* Open Graph object type. Defaults to 'website'. */
  ogType?: string;
  /* Per-page JSON-LD toggles. Omitted on most pages, so nothing is rendered;
     the home page opts into Organization + WebSite + Service + FAQPage. */
  structuredData?: {
    organization?: boolean;
    website?: boolean;
    service?: boolean;
    faq?: boolean;
    breadcrumbs?: { name: string; url: string }[];
  };
}

const {
  title,
  description,
  image,
  ogType = 'website',
  structuredData,
} = Astro.props;
const fullTitle = `${title} | Hive`;

// Absolute social-card URL. Astro.site is https://hive.scubed.co; the fallback
// is the build-time rasterized cover at public/og/default.png.
const ogImage = new URL(image ?? '/og/default.png', Astro.site).href;
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0c0e12" />
    <link rel="canonical" href={Astro.url.href} />

    <!-- Favicons. Concept 1 containment-vault mark. Same-origin public assets,
         fine under the img-src 'self' data: CSP. -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!--
      hreflang cross-links. This site (.co) is the global default; the Bangladesh
      site (.com.bd) is the locale variant. Each page self-canonicals above, so
      the two sites cross-link as locale alternates rather than duplicates. The
      geo-router Worker injects the matching headers on the .com.bd side. Never
      switch the geo redirect to 301, or one site will be de-indexed.
    -->
    <link rel="alternate" hreflang="en" href={Astro.url.href} />
    <link rel="alternate" hreflang="en-CA" href={Astro.url.href} />
    <link rel="alternate" hreflang="x-default" href={Astro.url.href} />
    <link
      rel="alternate"
      hreflang="en-BD"
      href={`https://hive.scubed.com.bd${Astro.url.pathname}`}
    />

    <!-- Preload the two above-the-fold faces only. -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={fraunces600}
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={inter400}
      crossorigin="anonymous"
    />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="Hive" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${title} on-premises AI`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${title} on-premises AI`} />

    {/* Per-page JSON-LD. Renders nothing unless a page opts in. */}
    {structuredData && <StructuredData {...structuredData} />}
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <div class="hex-lattice" aria-hidden="true"></div>

    <Nav />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        z-index: 100;
        background-color: var(--accent);
        color: var(--on-accent);
        padding: 10px 16px;
        font-weight: 600;
        border-radius: 0 0 8px 0;
      }

      .skip-link:focus {
        left: 0;
      }

      /* Faint hex-lattice motif. Pure CSS, fixed, decorative grain. On the dark
         canvas it reads as a barely-there light hairline texture (a faint forest
         tint), layered over the body vignette. Background transparent so the
         body radial glows show through. CSP-safe: data-uri in CSS, no script. */
      .hex-lattice {
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        opacity: 0.05;
        background-color: transparent;
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='56' height='100' viewBox='0 0 56 100'><g fill='none' stroke='%237cc4a2' stroke-width='1'><path d='M28 0 L56 16 L56 50 L28 66 L0 50 L0 16 Z'/><path d='M28 66 L56 82 L56 116 M28 66 L0 82 L0 116'/></g></svg>");
        background-repeat: repeat;
        background-size: 56px 100px;
      }
    </style>
  </body>
</html>
