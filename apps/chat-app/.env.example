# ===== Hive chat-app (LibreChat v0.7.9 fork) =====
# Phase 19 boot target: docker compose --env-file ../../.env --profile local up chat-app
# Phase 24 owns OCI deploy (out of Phase 19 scope).
#
# Upstream LibreChat reference env vars preserved at .env.upstream.example
# This file is the Hive-curated subset actually consumed by docker-compose.

# ─── LibreChat core ───
HOST=0.0.0.0
PORT=3080
DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080
NODE_ENV=development

# ─── MongoDB ───
# Atlas M0 free 512MB recommended for staging/soft-launch; local mongo for dev profile.
# Staging:    MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/hive-chat?retryWrites=true&w=majority
# Local dev:  MONGO_URI=mongodb://mongo:27017/hive-chat
MONGO_URI=mongodb://mongo:27017/hive-chat

# ─── Hive edge-api (single OpenAI-compatible provider) ───
HIVE_EDGE_API_BASE_URL=http://edge-api:8080/v1
HIVE_EDGE_API_KEY=

# ─── Auth (Phase 19 placeholder; Phase 20 swaps to Supabase) ───
JWT_SECRET=replace-me-phase-19-only
JWT_REFRESH_SECRET=replace-me-phase-19-only

# ─── Telemetry ───
DEBUG_LOGGING=false
DEBUG_CONSOLE=false

# ─── Auth providers (Phase 19 leaves email-only; Phase 20 swaps to Supabase) ───
ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false

# ─── Search / Meilisearch (LibreChat optional; off in Phase 19) ───
SEARCH=false
MEILI_NO_ANALYTICS=true

# ─── RAG sidecar (Phase 22 owns; off in Phase 19) ───
RAG_API_URL=
RAG_PORT=
